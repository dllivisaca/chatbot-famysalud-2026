PORT=3000
APP_ENV=production
TZ=America/Guayaquil
APP_TIMEZONE=America/Guayaquil
ENABLE_APPOINTMENT_BOOKING=false
ENABLE_AI_RESPONSES=false
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
VERIFY_TOKEN=
# Opcion 1: URL completa del endpoint de catalogo.
CHATBOT_CATALOG_URL=http://localhost/agendamiento-de-citas-famysalud/public/chatbot/catalogo-servicios
# Opcion 2: base + ruta. Usar si local y produccion tienen rutas distintas.
# CHATBOT_CATALOG_BASE_URL=http://localhost/agendamiento-de-citas-famysalud/public
# CHATBOT_CATALOG_PATH=/chatbot/catalogo-servicios
# Produccion ejemplo:
# CHATBOT_CATALOG_BASE_URL=https://tu-dominio.com
# CHATBOT_CATALOG_PATH=/ruta-produccion/catalogo-servicios
SESSION_TTL_MINUTES=15
CATALOG_CACHE_TTL_MINUTES=10
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
EVENT_HASH_SALT=
INTERNAL_RESULTS_WHATSAPP_TO=
RESULTS_INTERNAL_EMAIL=
RESULTS_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
